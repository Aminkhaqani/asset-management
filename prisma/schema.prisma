generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("technician")
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inspections        Inspection[]
  assignedWorkOrders WorkOrder[]  @relation("AssignedTechnician")
  createdFaults      Fault[]      @relation("FaultReporter")
  approvals          WorkOrder[]  @relation("Approver")
}

model AssetCategory {
  id          String  @id @default(cuid())
  nameFa      String
  nameEn      String
  assetType   String  @default("equipment")
  standardKey String? @unique
  icon        String?
  color       String?
  sortOrder   Int     @default(0)

  assets Asset[]

  @@index([assetType])
}

model Location {
  id       String     @id @default(cuid())
  name     String
  floor    String?
  zone     String?
  building String?
  parentId String?
  parent   Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children Location[] @relation("LocationHierarchy")

  assets Asset[]
}

model Asset {
  id                     String        @id @default(cuid())
  assetCode              String        @unique
  nameFa                 String
  nameEn                 String?
  assetType              String        @default("equipment")
  lifecycleStage         String        @default("operation")
  assetPortfolio         String?
  requiredFunction       String?
  valueContribution      String?
  performanceTarget      String?
  riskImpact             String        @default("medium")
  riskLikelihood         String        @default("medium")
  regulatoryRequirements String?
  categoryId             String
  category               AssetCategory @relation(fields: [categoryId], references: [id])
  brand                  String?
  model                  String?
  serialNumber           String?
  locationId             String
  location               Location      @relation(fields: [locationId], references: [id])
  installDate            DateTime?
  warrantyExpiry         DateTime?
  capacity               String?
  specifications         String?
  customFields           Json          @default("{}")
  criticality            String        @default("medium")
  status                 String        @default("active")
  qrCode                 String        @unique
  notes                  String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  inspections Inspection[]
  faults      Fault[]
  workOrders  WorkOrder[]
  timeline    TimelineEvent[]
  attachments AssetAttachment[]
  checklists  Checklist[]
  pmPlans     PreventiveMaintenancePlan[]

  @@index([assetType])
  @@index([lifecycleStage])
  @@index([status])
  @@index([categoryId])
  @@index([locationId])
}

model AssetAttachment {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fileName  String
  fileType  String
  fileUrl   String
  fileSize  Int?
  createdAt DateTime @default(now())
}

model Inspection {
  id           String   @id @default(cuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id])
  inspectorId  String
  inspector    User     @relation(fields: [inspectorId], references: [id])
  date         DateTime @default(now())
  shift        String?
  status       String   @default("normal")
  readings     String?
  runningHours Float?
  faultAlarms  String?
  oilLevel     String?
  vibration    String?
  noise        String?
  notes        String?
  photos       String?
  createdAt    DateTime @default(now())

  @@index([assetId, date])
  @@index([inspectorId])
  @@index([status])
}

model Fault {
  id              String    @id @default(cuid())
  assetId         String
  asset           Asset     @relation(fields: [assetId], references: [id])
  reportedById    String
  reportedBy      User      @relation("FaultReporter", fields: [reportedById], references: [id])
  faultType       String
  failureMode     String?
  failureCause    String?
  failureEffect   String?
  detectionMethod String?
  priority        String    @default("medium")
  status          String    @default("open")
  description     String
  reportedAt      DateTime  @default(now())
  resolvedAt      DateTime?
  resolution      String?
  photos          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workOrders WorkOrder[]

  @@index([assetId, reportedAt])
  @@index([reportedById])
  @@index([status])
  @@index([priority])
}

model WorkOrder {
  id                     String                     @id @default(cuid())
  type                   String
  assetId                String
  asset                  Asset                      @relation(fields: [assetId], references: [id])
  faultId                String?
  fault                  Fault?                     @relation(fields: [faultId], references: [id])
  title                  String
  description            String?
  maintenanceSubtype     String?
  maintenanceActivity    String?
  requiredFunction       String?
  failureMode            String?
  failureCause           String?
  downtimeHours          Float?
  priority               String                     @default("medium")
  status                 String                     @default("pending")
  assignedToId           String?
  assignedTo             User?                      @relation("AssignedTechnician", fields: [assignedToId], references: [id])
  approvedById           String?
  approvedBy             User?                      @relation("Approver", fields: [approvedById], references: [id])
  scheduledDate          DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  approvedAt             DateTime?
  partsConsumed          String?
  photos                 String?
  notes                  String?
  recurrence             String?
  nextDueDate            DateTime?
  repairType             String                     @default("internal")
  workshopId             String?
  workshop               Workshop?                  @relation(fields: [workshopId], references: [id])
  sentToWorkshopAt       DateTime?
  returnedFromWorkshopAt DateTime?
  workshopCost           Float?
  workshopInvoiceNumber  String?
  pmPlanId               String?
  pmPlan                 PreventiveMaintenancePlan? @relation(fields: [pmPlanId], references: [id])
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  @@index([assetId, createdAt])
  @@index([assignedToId])
  @@index([status])
  @@index([type])
  @@index([scheduledDate])
}

model Workshop {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  phone         String?
  address       String?
  contactPerson String?
  specialty     String?
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workOrders WorkOrder[]
}

model Checklist {
  id         String    @id @default(cuid())
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  title      String
  type       String
  frequency  String?
  items      String
  isActive   Boolean   @default(true)
  lastDoneAt DateTime?
  nextDueAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model TimelineEvent {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  eventType   String
  title       String
  description String?
  performedBy String?
  eventDate   DateTime @default(now())
  relatedId   String?
  relatedType String?
  createdAt   DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  type        String
  isRead      Boolean  @default(false)
  relatedId   String?
  relatedType String?
  createdAt   DateTime @default(now())
}

model PreventiveMaintenancePlan {
  id                       String    @id @default(cuid())
  assetId                  String
  asset                    Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  title                    String
  description              String?
  isActive                 Boolean   @default(true)
  // time-based trigger
  intervalDays             Int?
  lastServiceAt            DateTime?
  nextDueAt                DateTime?
  // running-hours-based trigger
  intervalRunningHours     Float?
  lastServiceHours         Float?
  nextDueRunningHours      Float?
  // generation control
  leadTimeDays             Int       @default(3)
  autoCreateWorkOrder      Boolean   @default(true)
  lastGeneratedAt          DateTime?
  lastGeneratedWorkOrderId String?
  priority                 String    @default("medium")
  checklistTemplate        String?
  notes                    String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  workOrders WorkOrder[]

  @@index([assetId])
  @@index([isActive])
  @@index([nextDueAt])
}
