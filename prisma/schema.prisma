generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("technician")
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inspections       Inspection[]
  assignedWorkOrders WorkOrder[] @relation("AssignedTechnician")
  createdFaults     Fault[]      @relation("FaultReporter")
  approvals         WorkOrder[]  @relation("Approver")
}

model AssetCategory {
  id        String  @id @default(cuid())
  nameFa    String
  nameEn    String
  icon      String?
  color     String?
  sortOrder Int     @default(0)

  assets Asset[]
}

model Location {
  id       String  @id @default(cuid())
  name     String
  floor    String?
  zone     String?
  building String?
  parentId String?
  parent   Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children Location[] @relation("LocationHierarchy")

  assets Asset[]
}

model Asset {
  id             String    @id @default(cuid())
  assetCode      String    @unique
  nameFa         String
  nameEn         String?
  categoryId     String
  category       AssetCategory @relation(fields: [categoryId], references: [id])
  brand          String?
  model          String?
  serialNumber   String?
  locationId     String
  location       Location  @relation(fields: [locationId], references: [id])
  installDate    DateTime?
  warrantyExpiry DateTime?
  capacity       String?
  specifications String?
  criticality    String    @default("medium")
  status         String    @default("active")
  qrCode         String    @unique
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  inspections Inspection[]
  faults      Fault[]
  workOrders  WorkOrder[]
  timeline    TimelineEvent[]
  attachments AssetAttachment[]
  checklists  Checklist[]
}

model AssetAttachment {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fileName  String
  fileType  String
  fileUrl   String
  fileSize  Int?
  createdAt DateTime @default(now())
}

model Inspection {
  id           String   @id @default(cuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id])
  inspectorId  String
  inspector    User     @relation(fields: [inspectorId], references: [id])
  date         DateTime @default(now())
  shift        String?
  status       String   @default("normal")
  readings     String?
  runningHours Float?
  faultAlarms  String?
  oilLevel     String?
  vibration    String?
  noise        String?
  notes        String?
  photos       String?
  createdAt    DateTime @default(now())
}

model Fault {
  id           String    @id @default(cuid())
  assetId      String
  asset        Asset     @relation(fields: [assetId], references: [id])
  reportedById String
  reportedBy   User      @relation("FaultReporter", fields: [reportedById], references: [id])
  faultType    String
  priority     String    @default("medium")
  status       String    @default("open")
  description  String
  reportedAt   DateTime  @default(now())
  resolvedAt   DateTime?
  resolution   String?
  photos       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workOrders WorkOrder[]
}

model WorkOrder {
  id            String    @id @default(cuid())
  type          String
  assetId       String
  asset         Asset     @relation(fields: [assetId], references: [id])
  faultId       String?
  fault         Fault?    @relation(fields: [faultId], references: [id])
  title         String
  description   String?
  priority      String    @default("medium")
  status        String    @default("pending")
  assignedToId  String?
  assignedTo    User?     @relation("AssignedTechnician", fields: [assignedToId], references: [id])
  approvedById  String?
  approvedBy    User?     @relation("Approver", fields: [approvedById], references: [id])
  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  approvedAt    DateTime?
  partsConsumed String?
  photos        String?
  notes         String?
  recurrence    String?
  nextDueDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Checklist {
  id        String    @id @default(cuid())
  assetId   String
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  title     String
  type      String
  frequency String?
  items     String
  isActive  Boolean   @default(true)
  lastDoneAt DateTime?
  nextDueAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model TimelineEvent {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  eventType   String
  title       String
  description String?
  performedBy String?
  eventDate   DateTime @default(now())
  relatedId   String?
  relatedType String?
  createdAt   DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  message     String
  type        String
  isRead      Boolean  @default(false)
  relatedId   String?
  relatedType String?
  createdAt   DateTime @default(now())
}
